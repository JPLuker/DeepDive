# Copy this file to .env and fill in your own values.
# Get CLIENT_ID / CLIENT_SECRET by creating an app at:
# https://developer.spotify.com/dashboard

SPOTIPY_CLIENT_ID=your_client_id_here
SPOTIPY_CLIENT_SECRET=your_client_secret_here

# Must exactly match a Redirect URI you add in the Spotify app settings
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Any random string, used to sign Flask session cookies
FLASK_SECRET_KEY=change_this_to_something_random

# Host/port the app listens on
DEEPDIVE_HOST=127.0.0.1
DEEPDIVE_PORT=8888
